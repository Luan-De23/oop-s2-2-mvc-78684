@model IEnumerable<FoodSafety.Library.FollowUp>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>FollowUp</h1>

<p>
    <a class="badge bg-success text-white fs-6 p-2 text-decoration-none" asp-action="Create">Create New</a>
</p>
<table class="table table-striped">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.DueDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ClosedDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Inspection)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.DueDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ClosedDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Inspection.Notes)
            </td>
            <td>
                
                <a class="badge bg-primary text-white fs-6 p-2 text-decoration-none" asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a class="badge bg-secondary text-white fs-6 p-2 text-decoration-none" asp-action="Details" asp-route-id="@item.Id">Details</a>
                @if (User.IsInRole("Admin"))
                {
                    <label> | </label>
                    <a class="badge bg-danger text-white fs-6 p-2 text-decoration-none" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                }
            </td>
        </tr>
}
    </tbody>
</table>
