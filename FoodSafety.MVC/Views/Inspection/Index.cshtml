@model IEnumerable<FoodSafety.Library.Inspection>

@{
    ViewData["Title"] = "Index";
}

<h1>Inspection</h1>

<p>
    <a class="badge bg-success text-white fs-6 p-2 text-decoration-none" asp-action="Create">Create New</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.InspectionDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Score)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.OutCome)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Notes)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Premises)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.InspectionDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Score)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.OutCome)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Notes)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Premises.Address)
            </td>
            <td>
                <a class="badge bg-primary text-white fs-6 p-2 text-decoration-none" asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a class="badge bg-secondary text-white fs-6 p-2 text-decoration-none" asp-action="Details" asp-route-id="@item.Id">Details</a> 
                @if (User.IsInRole("Admin"))
                {
                    <label> | </label>
                    <a class="badge bg-danger text-white fs-6 p-2 text-decoration-none" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                }
            </td>
        </tr>
}
    </tbody>
</table>